---
---
<style>
  .terminal {
    border-radius: 8px;
    border: 1px solid var(--appctl-border);
    background: var(--appctl-surface);
    overflow: hidden;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--appctl-fg);
  }
  .title-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--appctl-border);
    background: #050505;
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .dot.r { background: #ff5f56; }
  .dot.y { background: #ffbd2e; }
  .dot.g { background: #27c93f; }
  .title {
    margin-left: 10px;
    font-size: 12px;
    color: var(--appctl-muted);
  }
  .body {
    padding: 18px 18px 22px;
    display: grid;
    gap: 10px;
    line-height: 1.55;
  }
  .prompt { color: var(--appctl-fg); }
  .user { color: var(--appctl-fg); }
  .out { color: var(--appctl-fg-dim); }
  .ok { color: var(--appctl-fg); }
  .tag {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 3px;
    background: transparent;
    color: var(--appctl-muted);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--appctl-border);
    margin-right: 8px;
  }
  .line { display: block; }
</style>

<div class="terminal" role="img" aria-label="Terminal showing an appctl chat session refunding an order">
  <div class="title-bar">
    <span class="dot r"></span>
    <span class="dot y"></span>
    <span class="dot g"></span>
    <span class="title">appctl chat · billing</span>
  </div>
  <div class="body">
    <span class="line"><span class="prompt">appctl[app · gemini]▶</span> <span class="user">refund order 1042 as a one-time courtesy</span></span>
    <span class="line"><span class="tag">plan</span> refunds.create · amount=49.00 · reason="courtesy"</span>
    <span class="line"><span class="tag">call</span> POST /api/refunds/ 201 Created</span>
    <span class="line ok">refunded $49.00 for order #1042</span>
    <span class="line"></span>
    <span class="line"><span class="prompt">appctl[app · gemini]▶</span> <span class="user">did this ever happen before for this customer?</span></span>
    <span class="line"><span class="tag">call</span> GET /api/refunds/?customer=14 200 OK</span>
    <span class="line out">two prior refunds in the last 90 days</span>
  </div>
</div>
