---
import '../styles/tokens.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import Landing from '../components/Landing.astro';

const base = import.meta.env.BASE_URL;
const ogUrl = new URL('og.png', Astro.site ?? 'https://esubaalew.github.io/').toString();
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>appctl — Talk to your app in plain English</title>
    <meta
      name="description"
      content="appctl introspects your app, generates tools, and runs an auditable agent loop. Works with Django, Rails, Laravel, ASP.NET, Supabase, SQL, and more."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={Astro.site?.href ?? 'https://esubaalew.github.io/appctl/'} />
    <meta property="og:title" content="appctl" />
    <meta
      property="og:description"
      content="Talk to your app in plain English. appctl introspects your app, generates tools, and runs an auditable agent loop."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />
  </head>
  <body>
    <Landing />
  </body>
</html>
